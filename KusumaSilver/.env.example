# Copy to .env.local for development. NEVER commit real values.

# --- Sanity (existing) ---
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
# Write token — required for order creation (and reads once the dataset is
# private, which it MUST be in production: orders contain customer contacts).
SANITY_API_TOKEN=

# --- Currency display ---
# 1 USD in IDR; USD is display-only, IDR is authoritative.
NEXT_PUBLIC_EXCHANGE_RATE_IDR_PER_USD=16000

# --- Midtrans (Snap) ---
# Use SANDBOX keys in development (dashboard.sandbox.midtrans.com).
# Server key: SERVER ONLY — never expose with NEXT_PUBLIC_.
MIDTRANS_SERVER_KEY=
# Client key is safe to expose; snap.js requires it in the browser.
NEXT_PUBLIC_MIDTRANS_CLIENT_KEY=
# Leave unset (or false) for sandbox; set true only for the production launch.
MIDTRANS_IS_PRODUCTION=false
